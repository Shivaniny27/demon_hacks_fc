# ─────────────────────────────────────────────────────────────────────────────
# LoopSense + LoopNav — Environment Variables Template
# Copy to .env and fill in real values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local: createdb loopsense  (PostgreSQL 15+ required)
# Cloud: https://neon.tech  (free tier)
DATABASE_URL=postgresql+asyncpg://<user>@localhost:5432/loopsense

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local: brew install redis && brew services start redis
# Cloud: https://redis.com/try-free
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────────────────────
# CTA APIs
# ─────────────────────────────────────────────────────────────────────────────
# CTA Train Tracker (free key) — https://www.transitchicago.com/developers/traintrackerapply.aspx
CTA_TRAIN_TRACKER_KEY=
# CTA Bus Tracker (free key) — https://www.ctabustracker.com/bustime/api/v2/
CTA_BUS_TRACKER_KEY=
# CTA Customer Alerts (public, no key required)
CTA_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Chicago Data Portal — ONE token covers all datasets
# Register: https://data.cityofchicago.org → Developer Settings → App Token
# ─────────────────────────────────────────────────────────────────────────────
CHICAGO_APP_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Weather — OpenWeatherMap (free, 1k calls/day)
# Register: https://openweathermap.org → API Keys
# ─────────────────────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# AI
# ─────────────────────────────────────────────────────────────────────────────
# Groq — Llama 3.2 3B hazard classification (free) — https://console.groq.com
GROQ_API_KEY=
# Anthropic Claude — LoopNav NL routing — https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────────────────
# true  = 16-node stub graph (dev default, no external data needed)
# false = real graph from app/graph/loader.py
USE_STUB_GRAPH=true
DEBUG=true
